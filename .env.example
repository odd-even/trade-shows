# Copy to .env and fill in (never commit .env)
# Used by scripts/email_ingest.py

# Microsoft 365 example:
#   IMAP_HOST=outlook.office365.com
#   IMAP_USER=tradeshows@jollyfarmer.com
# Gmail example:
#   IMAP_HOST=imap.gmail.com
#   IMAP_USER=tradeshows.ingest@gmail.com

IMAP_HOST=outlook.office365.com
IMAP_USER=tradeshows@jollyfarmer.com
IMAP_PASSWORD=

# Optional — defaults shown
IMAP_PORT=993
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true

# How often to poll when running as a daemon (seconds)
POLL_INTERVAL_SECONDS=300
